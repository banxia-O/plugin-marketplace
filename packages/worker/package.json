{
  "name": "@ppx/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deploy": "wrangler deploy",
    "seed:gen": "node scripts/gen-seed.mjs",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:seed:local": "wrangler d1 execute DB --local --file=seed/plugins.sql",
    "db:reset:local": "rm -rf .wrangler/state && pnpm db:migrate:local && pnpm db:seed:local"
  },
  "dependencies": {
    "@ppx/shared": "workspace:*",
    "hono": "^4.6.16"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.7.3",
    "wrangler": "^3.99.0"
  }
}
